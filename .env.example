# ── DB (Docker) ──────────────────────────────────────────────────────────────
# 강한 무작위 비번 권장: openssl rand -hex 32
MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_DATABASE=hailmary
MYSQL_USER=hailmary_app
MYSQL_PASSWORD=change_me_app_password

# 애플리케이션 DB 접속 (앱 전용 사용자 사용, root 금지)
DATABASE_URL=mysql+aiomysql://hailmary_app:change_me_app_password@127.0.0.1:3307/hailmary

# ── 외부 서비스 ──────────────────────────────────────────────────────────────
FORTUNETELLER_URL=http://localhost:4000
PAYAPP_BASE_URL=https://api.payapp.kr
PAYAPP_API_KEY=your_payapp_api_key

# 토스페이먼츠 v2 결제위젯 (백엔드 결제 승인용 시크릿 키)
# 문서용 테스트 키: test_gsk_docs_OaPz8L5KdmQXkzRz3y47BMw6
TOSS_SECRET_KEY=your_toss_widget_secret_key
TOSS_BASE_URL=https://api.tosspayments.com
CLAUDE_API_KEY=your_claude_api_key
CLAUDE_MODEL=claude-sonnet-4-6

# Amplitude HTTP API V2 (백엔드 payment_completed 이벤트 발화용).
# 프론트의 NEXT_PUBLIC_AMPLITUDE_API_KEY 와 동일 키를 사용해도 무방하지만, 백엔드에서는
# 클라이언트로 노출되지 않도록 별도 변수로 관리한다. 미설정 시 백엔드 이벤트만 skip
# (결제 자체에는 영향 없음).
AMPLITUDE_API_KEY=your_amplitude_api_key
AMPLITUDE_BASE_URL=https://api2.amplitude.com

# ── 앱 환경 ──────────────────────────────────────────────────────────────────
APP_ENV=local
DEBUG=false
